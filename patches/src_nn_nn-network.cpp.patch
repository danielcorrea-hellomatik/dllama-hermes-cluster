+}
+
+static inline void setSocketBuffers(int socket) {
+#ifndef _WIN32
+    // 8MB buffers - importante en cluster Pi 5 para reducir blocking en sync
+    int bufSize = 8 * 1024 * 1024;
+    setsockopt(socket, SOL_SOCKET, SO_RCVBUF, (char*)&bufSize, sizeof(int));
+    setsockopt(socket, SOL_SOCKET, SO_SNDBUF, (char*)&bufSize, sizeof(int));
+#ifdef TCP_NODELAY
+    int flag = 1;
+    setsockopt(socket, IPPROTO_TCP, TCP_NODELAY, (char*)&flag, sizeof(int));
+#endif
+    // === Hellomatik patches: socket-level latency reduction ===
+    // SO_BUSY_POLL: spin-poll en kernel hasta N microsegundos antes de bloquear
+    // Reduce latencia syscall en sync round-trips LAN
+#ifdef SO_BUSY_POLL
+    int busyPoll = 50; // 50 microseconds polling
+    setsockopt(socket, SOL_SOCKET, SO_BUSY_POLL, (char*)&busyPoll, sizeof(int));
+#endif
+    // SO_PRIORITY: clase de paquete TC más alta = menos delay en queue
+#ifdef SO_PRIORITY
+    int prio = 6; // priorización paquetes dllama
+    setsockopt(socket, SOL_SOCKET, SO_PRIORITY, (char*)&prio, sizeof(int));
+#endif
+    // SO_INCOMING_CPU: bind socket a CPU local para cache locality
+    // (kernel >=5.0 ignora salvo workloads especificos)
+#ifdef SO_INCOMING_CPU
+    int cpu = -1; // -1 = auto-detect
+    setsockopt(socket, SOL_SOCKET, SO_INCOMING_CPU, (char*)&cpu, sizeof(int));
 #endif
 #endif
 }
