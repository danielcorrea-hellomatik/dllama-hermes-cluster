@@ -61,6 +61,37 @@
     int value = 1;
     if (setsockopt(socket, IPPROTO_TCP, TCP_QUICKACK, (char*)&value, sizeof(int)) < 0)
         throw std::runtime_error("Error setting quick ack");
+#endif
